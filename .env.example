NODE_ENV=development
PORT=3001

# CORS（部署到 Render 時必填）
FRONTEND_URL=http://localhost:3000


# Database
DATABASE_URL=mongodb+srv://<username>:<password>@cluster0.ddj63.mongodb.net/?appName=Cluster0

# Redis（本地 Docker 不需 TLS；Upstash 等雲端需 TLS 或使用 REDIS_URL）
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_USE_TLS=false
# 或直接貼 Upstash 提供的 rediss:// 連線字串（優先於上方設定）
REDIS_URL=
REDIS_TTL=60 #驗證碼冷卻期間(秒)
REDIS_CODE_TTL=300 # 驗證碼有效期限(秒)

# JWT
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# Government API sync
GOV_ANIMAL_API_URL=
GOV_SYNC_CRON=0 * * * *

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ECPay
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_RETURN_URL=
